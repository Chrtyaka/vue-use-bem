{
  "name": "vue-use-bem",
  "version": "1.1.9",
  "author": "Slava Cherkesov",
  "license": "MIT",
  "type": "module",
  "description": "A simple utility for generate BEM classes",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "build": "rollup -c",
    "test": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "homepage": "https://github.com/Chrtyaka/vue-use-bem#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chrtyaka/vue-use-bem"
  },
  "keywords": [
    "vue",
    "bem"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "files": [
    "./dist",
    "./LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@vue/test-utils": "2.4.6",
    "happy-dom": "20.9.0",
    "lefthook": "2.1.5",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "rollup": "4.60.1",
    "semantic-release": "25.0.3",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitepress": "1.6.3",
    "vitest": "3.2.4",
    "vue": "3.5.32"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  }
}
